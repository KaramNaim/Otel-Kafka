{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=OTelDb;Username=postgres;Password=postgres"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Information"
      }
    }
  },
  "OpenTelemetry": {
    "ServiceName": "OTel.Api",
    "ConsoleExporter": false,
    "Jaeger": {
      "Enabled": true,
      "Endpoint": "http://localhost:4317"
    },
    "Grafana": {
      "Enabled": true,
      "PrometheusEndpoint": "/metrics",
      "OtlpEndpoint": "http://localhost:4317"
    },
    "Loki": {
      "Enabled": true,
      "Endpoint": "http://localhost:3100/otlp/v1/logs"
    },
    "CloudWatch": {
      "Enabled": false,
      "Region": "us-east-1",
      "Namespace": "OTel/Api"
    }
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "Topic": "order-events",
    "ConsumerGroup": "order-events-group"
  },
  "AllowedHosts": "*"
}
